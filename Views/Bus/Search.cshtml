@model IEnumerable<Travel_Bud.Models.Route>

@{
    ViewData["Title"] = "Search Buses";
}

<form asp-action="Search" method="get" class="booking-form">
    <section class="hero">
        <div class="overlay"></div>
          <div class="hero-content">

            <h1>Search and Book Cheap Bus Tickets</h1>


            <div class="form-row">
                <label>Departure:</label>
                <input type="text" name="startLocation" required />
            </div>
            <div class="form-row">
                <label>Destination:</label>
                <input type="text" name="destination" required />
            </div>
            <div class=" form-row">
                <label>Travel Date:</label>
                <input type="date" name="travelDate" min="@DateTime.Now.ToString("yyyy-MM-dd")" required />
            </div>
            <button class="btn" type="submit">Find Buses</button>
         </div>
    </section>
</form>

<hr />

@if (Model != null && Model.Any())
{
    <h3>Available Buses</h3>
    <table>
        <thead>
            <tr>
                <th>Bus</th>
                <th>Operator</th>
                <th>Departure</th>
                <th>Price</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var route in Model)
            {
                <tr>
                    <td>@route.Bus.BusName</td>
                    <td>@route.Bus.Operator</td>
                    <td>@route.DepartureTime</td>
                    <td>@route.Price</td>
                    <td>
                        <a asp-action="Book" asp-route-id="@route.RouteId">Book</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No buses found yet. Please search above.</p>
}

            <style>
    /* Reset */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    /* Hero Section */
    .hero {
        height: 100vh;
        background: url('https://png.pngtree.com/thumb_back/fh260/background/20241219/pngtree-travel-bus-on-a-beautiful-highway-image_16826753.jpg') center/cover no-repeat; /* Replace with your bus image */
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .hero .overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
        }

    .hero-content {
        position: relative;
        z-index: 1;
        text-align: center;
        color: white;
        max-width: 600px;
    }

        .hero-content h1 {
            margin-bottom: 20px;
            font-size: 2em;
        }

    /* Booking Form */
    .booking-form {
        background: rgba(255,255,255,0.9);
        padding: 5px;
        border-radius: 8px;
        color: #333;
    }

    .trip-type {
        margin-bottom: 15px;
    }

        .trip-type label {
            margin-right: 20px;
            font-weight: bold;
        }

    .form-row {
        display: flex;
        gap: 10px;
        margin-bottom: 15px;
    }

        .form-row input {
            flex: 1;
            padding: 5px;
            border: 1px solid #ccc;
            border-radius: 5px;
        }

    .btn {
        background: #f8c146;
        color: #343a40;
        padding: 10px 20px;
        border: none;
        font-weight: bold;
        border-radius: 5px;
        cursor: pointer;
    }

        .btn:hover {
            background: #ffc107;
        }
</style>