
@{

    Layout = null;
}
<h3 class="d-flex justify-content-between align-items-center">
    Bookings
   
</h3>

<table class="bookings-table">
    <thead>
        <tr>
            <th>Passenger</th>
            <th>Route</th>
            <th>Bus</th>
            <th>Departure</th>
            <th>Price</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var booking in Model)
        {
            <tr>
                <td>@booking.PassengerName</td>
                <td>@booking.Route.StartLocation → @booking.Route.Destination</td>
                <td>@booking.Route.Bus.BusName</td>
                <td>@booking.Route.DepartureTime.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@booking.Route.Price</td>
                <td>
                    <a asp-action="EditBooking" asp-route-id="@booking.BookingId">Edit</a>
                    <a asp-action="DeleteBooking" asp-route-id="@booking.BookingId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
<style>

    /* Bookings Table */
    .bookings-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
        font-family: Arial, sans-serif;
        background-color: #f9f9f9;
        box-shadow: 0 2px 6px rgba(0,0,0,0.1);
        border-radius: 6px;
        overflow: hidden;
    }

        /* Table Header */
        .bookings-table thead {
            background-color: #343a40; /* matches sidebar */
            color: #fff;
        }

            .bookings-table thead th {
                padding: 12px;
                text-align: left;
                font-weight: bold;
            }

        /* Table Rows */
        .bookings-table tbody tr {
            border-bottom: 1px solid #ddd;
        }

            .bookings-table tbody tr:nth-child(even) {
                background-color: #f1f1f1;
            }

        .bookings-table tbody td {
            padding: 10px;
        }

            /* Action Buttons */
            .bookings-table tbody td a {
                display: inline-block;
                padding: 6px 12px;
                background-color: #f8c146; /* consistent with Add Route button */
                color: #343a40;
                text-decoration: none;
                border-radius: 4px;
                font-weight: bold;
                transition: background-color 0.3s;
                margin-right: 5px;
            }

                .bookings-table tbody td a:hover {
                    background-color: #ffc107;
                    color: #212529;
                }
</style>