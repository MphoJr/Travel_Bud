@model IEnumerable<Travel_Bud.Models.Bookings>
@{
    ViewData["Title"] = "Admin Dashboard";
    var routes = ViewBag.Routes as List<Travel_Bud.Models.Route>;
}

<h2>Admin Dashboard</h2>

<h3>Bookings</h3>
<table>
    <thead>
        <tr>
            <th>Passenger</th>
            <th>Route</th>
            <th>Bus</th>
            <th>Departure</th>
            <th>Price</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var booking in Model)
        {
            <tr>
                <td>@booking.PassengerName</td>
                <td>@booking.Route.StartLocation → @booking.Route.Destination</td>
                <td>@booking.Route.Bus.BusName</td>
                <td>@booking.Route.DepartureTime</td>
                <td>@booking.Route.Price</td>
            </tr>
        }
    </tbody>
</table>

<h3>Add New Route</h3>
<form asp-action="AddRoute" method="post">
    <div>
        <label>Start Location:</label>
        <input type="text" name="StartLocation" required />
    </div>
    <div>
        <label>Destination:</label>
        <input type="text" name="Destination" required />
    </div>
    <div>
        <label>Departure Time:</label>
        <input type="datetime-local" name="DepartureTime" required />
    </div>
    <div>
        <label>Price:</label>
        <input type="number" step="0.01" name="Price" required />
    </div>
    <div>
        <label>Bus Id:</label>
        <input type="number" name="BusId" required />
    </div>
    <button type="submit">Add Route</button>
</form>