<h3>Bookings</h3>
<table>
    <thead>
        <tr>
            <th>Passenger</th>
            <th>Route</th>
            <th>Bus</th>
            <th>Departure</th>
            <th>Price</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var booking in Model)
        {
            <tr>
                <td>@booking.PassengerName</td>
                <td>@booking.Route.StartLocation → @booking.Route.Destination</td>
                <td>@booking.Route.Bus.BusName</td>
                <td>@booking.Route.DepartureTime</td>
                <td>@booking.Route.Price</td>
                <td>
                    <a asp-action="EditBooking" asp-route-id="@booking.BookingId">Edit</a> |
                    <a asp-action="DeleteBooking" asp-route-id="@booking.BookingId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<h3>Routes</h3>
<table>
    <thead>
        <tr>
            <th>Start</th>
            <th>Destination</th>
            <th>Departure</th>
            <th>Price</th>
            <th>Bus</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var route in ViewBag.Routes)
        {
            <tr>
                <td>@route.StartLocation</td>
                <td>@route.Destination</td>
                <td>@route.DepartureTime</td>
                <td>@route.Price</td>
                <td>@route.Bus.BusName</td>
                <td>
                    <a asp-action="EditRoute" asp-route-id="@route.RouteId">Edit</a> |
                    <a asp-action="DeleteRoute" asp-route-id="@route.RouteId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>