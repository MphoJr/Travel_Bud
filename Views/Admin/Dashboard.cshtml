@{
    Layout = null; // or keep your shared layout if you already have one
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <style>
        body {
            display: flex;
        }

        .sidebar {
            width: 220px;
            height: 100vh;
            background-color: #343a40;
            color: white;
            padding-top: 20px;
            position: fixed;
        }

            .sidebar a {
                color: white;
                text-decoration: none;
                display: block;
                padding: 10px 20px;
            }

                .sidebar a:hover {
                    background-color: #495057;
                }

        .content {
            margin-left: 220px;
            padding: 20px;
            width: 100%;
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <h4 class="text-center">Admin Panel</h4>
        <a asp-controller="Admin" asp-action="Dashboard">🏠 Dashboard</a>
        <a asp-controller="Admin" asp-action="AddRoute">➕ Add Route</a>
        <a asp-controller="Admin" asp-action="Bookings" asp-route-id="1">✏️ Edit Booking</a>
        <a asp-controller="Admin" asp-action="Logout">🚪 Logout</a>
    </div>

    <!-- Main Content -->
  


<h3>Routes</h3>
<table>
    <thead>
        <tr>
            <th>Start</th>
            <th>Destination</th>
            <th>Departure</th>
            <th>Price</th>
            <th>Bus</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var route in ViewBag.Routes)
        {
            <tr>
                <td>@route.StartLocation</td>
                <td>@route.Destination</td>
                <td>@route.DepartureTime</td>
                <td>@route.Price</td>
                <td>@route.Bus.BusName</td>
                <td>
                    <a asp-action="EditRoute" asp-route-id="@route.RouteId">Edit</a> |
                    <a asp-action="DeleteRoute" asp-route-id="@route.RouteId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
</body>
<